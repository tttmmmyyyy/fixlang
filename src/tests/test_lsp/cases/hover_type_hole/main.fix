module Main;

// `_` resolves to the concrete element type `I64`.
concrete : Array I64 = ([1, 2, 3] : Array _);

// `_` resolves to the generic type variable `a`.
genfill : I64 -> a -> Array a = |len, elem| (Array::fill(len, elem) : Array _);

// `_` of kind `* -> *` resolves to the `Array` type constructor.
empty : Array I64 = ([] : (_ : * -> *) I64);

// `_` resolves to a function's opaque return type.
counter : [?it : Iterator, Item ?it = I64] I64 -> ?it = |n| Iterator::range(0, n);
opaqued : Array I64 = (
    let it = (counter(3) : _);
    it.to_array
);

main : IO () = pure();
