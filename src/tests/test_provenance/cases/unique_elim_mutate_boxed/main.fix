module Main;

// Writing through a boxed value's data pointer clones the value when something else holds it, and
// hands back one nothing else holds. Both halves of that are declared: the check is dropped on a
// value already proven unique (rendered `[unique]`), and the value each write returns is `fresh`, so
// the next write has nothing left to check. The two variants declare the value at different
// positions of their result, so both are exercised here. The program prints a literal rather than a
// number because rendering one itself writes through a pointer, which would put a second, unrelated
// `mutate_boxed` in the dump.
main : IO ();
main = (
    let (mutated, _) = Array::fill(2, 0_U8).mutate_boxed(|_| pure());
    let (mutated_io, _) = *mutated.mutate_boxed_io(|_| pure());
    eval mutated_io;
    println("mutate_boxed")
);
