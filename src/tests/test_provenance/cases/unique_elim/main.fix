module Main;

// Exercises unique-check elimination dumped by `fix build --emit-rc-ir`. Each operation on a locally
// fresh (provably unique) value has its runtime uniqueness check dropped, which the dump renders with
// a `[unique]` marker; an operation on a value read out of a boxed container is of unknown sharing, so
// its check is kept and no marker appears.
// - `Array::set` on a fresh array -> `Array::set [unique]`; on a boxed-container element -> `Array::set`.
// - `Array::swap` on a fresh array -> `Array::swap [unique]`.
// - a generic `Array::act` on a fresh array -> its `unsafe_is_unique` folds to `is_unique[unique]`.
// - a boxed-struct field `set` on a fresh struct -> `set_0 [unique]`.
// - a fresh array passed through `assert_unique`, whose guard aborts rather than producing a value,
//   comes out fresh, so the `set` after it drops its check too.
// - an array built by `Array::from_map` (a `push_back` loop) comes out fresh, and the
//   `_unsafe_append_value_capacity_unchecked` core its `push_back` and `Array::fill` grow with folds
//   its check on the fresh array to `array_append_value [unique]`.
// - `Array::truncate` on a fresh array -> its `_unsafe_truncate_bounds_unchecked` core folds to
//   `array_truncate [unique]`.
// - `Array::reserve` on a fresh array -> its `_unsafe_set_capacity_bounds_unchecked` core folds to
//   `array_set_capacity [unique]` and reallocs in place.
// - `Array::append` into a fresh array -> its `_unsafe_append_capacity_bounds_unchecked` core folds
//   to `array_append_range [unique]`.
// - `_unsafe_grow_size` on a fresh array -> `array_grow_size [unique]`.
// - `unsafe_set_bounds_unchecked` on a fresh array -> `array_set_unchecked [unique]`.
type Rec = box struct { x : I64, y : I64 };

main : IO ();
main = (
    let fresh = Array::fill(4, 0);
    let fresh = fresh.set(1, 9);
    let fresh = fresh.swap(0, 3);
    let acted = fresh.act(2, |v| Option::some(v + 1)).as_some;

    let rec = Rec { x : 1, y : 2 };
    let rec = rec.set_x(10);

    let guarded = Array::fill(4, 0).assert_unique(|_|"the array is shared");
    let guarded = guarded.set(0, 7);

    let built = Array::from_map(3, |i| i);
    let built = built.set(0, 5);

    let trunc = Array::fill(4, 0).truncate(2);

    let reserved = Array::fill(2, 0).reserve(10);
    let reserved = reserved.set(0, 3);

    let appended = Array::fill(2, 0).reserve(5).append([9, 9, 9]);
    let appended = appended.set(0, 4);

    // `_unsafe_grow_size` on the fresh empty array; only its length is read, not the uninitialized
    // slots it exposes.
    let grown = (Array::empty(4)._unsafe_grow_size(4) : Array I64);

    let uset = Array::fill(4, 0).unsafe_set_bounds_unchecked(1, 7);

    let boxes = [[10], [20]];
    let inner = boxes.@(0);
    let inner = inner.set(0, 99);

    println $ (acted.@(2) + rec.@x + inner.@(0) + guarded.@(0) + built.@(0) + trunc.@(0) + reserved.@(0) + appended.@(0) + grown.@size + uset.@(1)).to_string
);
